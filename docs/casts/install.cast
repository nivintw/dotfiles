[182.942908, "o", "\u001b[1;34m==> Needs attention\u001b[0m\r\n"]
[182.94303, "o", "\u001b[33m\u26a0 Touch ID for sudo is enabled but NO fingerprint is enrolled \u2014 sudo will keep prompting for your \u001b[0m\r\n\u001b[33mpassword. Enroll one in System Settings \u2192 Touch ID & Password (or this Mac has no Touch ID \u001b[0m\r\n\u001b[33msensor).\u001b[0m\r\n"]
[182.943082, "o", "\u001b[33m\u26a0 backed up /Users/admin/.gitconfig -> /Users/admin/.gitconfig.pre-stow.bak and migrated its \u001b[0m\r\n\u001b[33mcontents into /Users/admin/.gitconfig_local\u001b[0m\r\n"]
[182.943155, "o", "\u001b[33m\u26a0 1Password not found \u2014 disabled commit signing in ~/.gitconfig_local (set commit.gpgsign yourself\u001b[0m\r\n\u001b[33mto re-enable).\u001b[0m\r\n"]
[182.943217, "o", "\u001b[33m\u26a0 1Password not signed in \u2014 skipping secret-backed servers; re-run after 'op signin' or export a \u001b[0m\r\n\u001b[33mGitHub PAT.\u001b[0m\r\n"]
[182.943271, "o", "\u001b[33m\u26a0 skipping '1password' (command not found: \u001b[0m\r\n\u001b[33m/Applications/1Password.app/Contents/MacOS/onepassword-mcp)\u001b[0m\r\n"]
[182.943319, "o", "\u001b[33m\u26a0 skipping 'github' (unresolved 1Password reference)\u001b[0m\r\n"]
[182.943372, "o", "\u001b[2m   re-run ~/dotfiles/install.sh to retry, or 'dotfiles-install --verify' to re-check.\u001b[0m\r\n"]
[182.943522, "o", "\u001b[2m   Restart your shell (or run 'exec fish') to pick everything up.\u001b[0m\r\n"]
