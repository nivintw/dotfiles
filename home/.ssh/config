# Machine-local host entries (homelab/bastion specifics, work hosts) live in an
# untracked ~/.ssh/config.local, created by install.sh and Include-d first so its
# values win — ssh uses the first matching value for most settings. Keep THIS
# tracked file generic and portable: no concrete hosts, IPs, or usernames. That
# rule is enforced by the `no-concrete-ssh-hosts` pre-commit hook.
Include ~/.ssh/config.local

HashKnownHosts yes

Host *
    IdentitiesOnly yes
    UseKeychain yes
    IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# github.com is universal and non-sensitive, so it stays here as the portable
# default. A machine-local override, if ever needed, can win via ~/.ssh/config.local.
Host github.com
  IdentityFile ~/.ssh/id_ed25519_1password_personal.pub
