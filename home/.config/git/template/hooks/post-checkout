#!/usr/bin/env bash
# SPDX-FileCopyrightText: © 2026 Tyler Nivin
# SPDX-License-Identifier: MIT

# Git post-checkout hook, distributed via init.templateDir (see ~/.gitconfig). git
# copies it into every newly cloned/init'd repo's .git/hooks/. On the FIRST checkout
# of a fresh clone, if the repo ships a pre-commit config, it either:
#   - notifies that hooks are available (default), or
#   - auto-installs them when you've opted in:
#       git config --file ~/.gitconfig_local dotfiles.autoInstallHooks true
#
# This hook never runs the cloned repo's own hooks — only "prek install" does, and
# only on the opt-in path. So a default clone executes no untrusted code.

prev_head="$1"
flag="$3" # 1 = branch checkout (a clone's initial checkout is one); 0 = file checkout

# Act only on the initial checkout of a fresh clone: a branch checkout whose previous
# HEAD is the null OID (clone starts from all-zeros). Skip ordinary branch switches.
null_oid='0000000000000000000000000000000000000000'
[ "$flag" = "1" ] || exit 0
case "$prev_head" in "$null_oid" | '') ;; *) exit 0 ;; esac

toplevel="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0

config=""
for c in .pre-commit-config.yaml .pre-commit-config.yml; do
  if [ -f "$toplevel/$c" ]; then
    config="$c"
    break
  fi
done
[ -n "$config" ] || exit 0

auto="$(git config --bool --get dotfiles.autoInstallHooks 2>/dev/null || echo false)"

if [ "$auto" = "true" ] && command -v prek >/dev/null 2>&1; then
  # Install shims for every hook type a repo might configure (each no-ops on a stage
  # the repo doesn't use). Run from the repo root.
  if (cd "$toplevel" && prek install \
    -t pre-commit -t pre-merge-commit -t pre-push -t pre-rebase -t prepare-commit-msg \
    -t commit-msg -t post-checkout -t post-commit -t post-merge -t post-rewrite \
    >/dev/null 2>&1); then
    printf '\033[1;32m[ok]\033[0m installed pre-commit hooks (%s) via prek\n' "$config" >&2
  else
    printf '\033[1;33m[!!]\033[0m could not auto-install pre-commit hooks; run "prek install" yourself\n' >&2
  fi
else
  printf '\033[1;34m==>\033[0m This repo defines pre-commit hooks (%s) but they are not installed.\n' "$config" >&2
  printf '    Run "prek install" to enable them (or set git config --global dotfiles.autoInstallHooks true to auto-install on clone).\n' >&2
fi

exit 0
