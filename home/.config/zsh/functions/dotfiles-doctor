# Check that the dotfiles install is healthy.
dotfiles-doctor() {
    # Resolve the repo without hardcoding ~/dotfiles: honor $DOTFILES, then the current
    # repo (so it works from any worktree you're cd'd into), then the conventional
    # checkout.
    local toplevel repo cand
    toplevel=$(git rev-parse --show-toplevel 2>/dev/null)
    for cand in "$DOTFILES" "$toplevel" "$HOME/dotfiles"; do
        # Skip an empty candidate ($DOTFILES unset / not in a git repo) so it can't
        # collapse to an absolute path and probe outside the repo. The installer package
        # marks the repo.
        if [[ -n "$cand" && -d "$cand/src/dotfiles_install" ]]; then
            repo=$cand
            break
        fi
    done
    if [[ -z "$repo" ]]; then
        echo "dotfiles-doctor: dotfiles repo not found (set \$DOTFILES or run from the dotfiles repo)" >&2
        return 1
    fi

    # `dotfiles-install --verify` reads only — no sudo, no mutation — and exits non-zero
    # when anything needs attention, so dotfiles-doctor is safe to run any time and
    # usable directly in a conditional. --no-sync uses the env as-is (never
    # reconciling/uninstalling deps — e.g. a dev checkout's pytest/ruff), keeping the
    # check truly read-only; the install already built the env.
    uv run --no-sync --project "$repo" dotfiles-install --verify
}
