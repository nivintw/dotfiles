# Copy stdin to the system clipboard (macOS/Linux/WSL). Cross-platform replacement for a
# bare `pbcopy`. macOS has pbcopy; WSL reaches the Windows clipboard via win32yank
# (preferred) or clip.exe; Linux uses the Wayland (wl-copy) or X11 (xclip/xsel) tool that's
# installed.
__clipboard_copy() {
    if is_macos; then
        pbcopy
    elif is_wsl && command -v win32yank.exe >/dev/null 2>&1; then
        # Prefer win32yank on WSL: it round-trips UTF-8 cleanly and adds no trailing newline,
        # unlike clip.exe, which mangles non-ASCII through the console codepage and appends a CR.
        win32yank.exe -i
    elif is_wsl && command -v clip.exe >/dev/null 2>&1; then
        clip.exe
    elif command -v wl-copy >/dev/null 2>&1 && [[ -n "$WAYLAND_DISPLAY" ]]; then
        # Gate wl-copy on a live Wayland display: with none (a headless box or an X11-only
        # session) it hangs or errors, so fall through to xclip/xsel instead of failing here.
        wl-copy
    elif command -v xclip >/dev/null 2>&1; then
        xclip -selection clipboard
    elif command -v xsel >/dev/null 2>&1; then
        xsel --clipboard --input
    else
        # No clipboard tool. Drain a *piped* stdin so the upstream `printf … |` producer
        # doesn't see a broken pipe — but never read an interactive tty, which would
        # block the shell waiting for Ctrl-D. Either way, report failure.
        [[ -t 0 ]] || cat >/dev/null
        return 1
    fi
}
