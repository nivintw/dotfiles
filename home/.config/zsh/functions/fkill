# Fuzzy-select and kill process(es). Default SIGTERM; pass a signal, e.g. fkill 9
fkill() {
    local signal=15
    [[ -n "$1" ]] && signal=$1

    # Validate the signal up front. A number is range-checked; a name is validated
    # case-insensitively (term / TERM / SIGTERM) against the signals this host's
    # `kill -l` actually knows — so a typo like `fkill TremK` is caught here rather than
    # deferred to `kill`, and a valid lowercase name no longer false-rejects.
    if [[ "$signal" =~ ^[0-9]+$ ]]; then
        # Bound numeric signals so 0 (a no-op probe) and out-of-range values like 999
        # don't reach `kill` (and then a pointless `sudo kill`).
        if (( signal < 1 || signal > 64 )); then
            echo "fkill: signal number '$signal' out of range (use 1-64)" >&2
            return 2
        fi
    else
        # Normalize the candidate to a bare uppercase name (drop an optional SIG).
        local name=${${(U)signal}#SIG}
        # Known names from `kill -l`, normalized the same way. Handles both the BSD
        # format (bare `HUP INT … TERM`) and the GNU format (`15) SIGTERM`): strip SIG,
        # then keep only alphabetic tokens so the `15)` ordinals fall away.
        local -a known
        known=($(kill -l 2>/dev/null | tr ' \t' '\n\n' | tr '[:lower:]' '[:upper:]' | sed 's/^SIG//' | grep -E '^[A-Z][A-Z0-9]*$'))
        local candidate found=0
        for candidate in "${known[@]}"; do
            [[ "$candidate" == "$name" ]] && { found=1; break }
        done
        if (( ! found )); then
            echo "fkill: invalid signal '$signal' (use a number like 9 or a name like TERM)" >&2
            return 2
        fi
        signal=$name
    fi

    local pids
    pids=$(
        ps -axo pid,user,%cpu,%mem,command \
            | fzf --multi --header-lines=1 --prompt "kill -$signal > " \
            | awk '{print $1}'
    )
    [[ -n "$pids" ]] || return

    local pid reply
    for pid in ${(f)pids}; do
        echo "Killing $pid (signal $signal)"
        if ! kill -$signal "$pid" 2>/dev/null; then
            # The kill failed. If the process is still alive it's likely a permissions
            # issue — offer to retry under sudo, but never escalate silently. (If it
            # simply exited between selection and signal, skip.)
            if ps -p "$pid" >/dev/null 2>&1; then
                # reply is declared once above (with pid), not re-declared per iteration:
                # a bare `local` re-declared on an already-local var prints "name=value"
                # to stdout in zsh — exactly the kind of stray output a retry prompt
                # loop would trigger on the second failed kill.
                read -r "reply?  kill $pid failed — retry with sudo? [y/N] "
                if [[ "$reply" =~ ^[Yy] ]]; then
                    sudo kill -$signal "$pid"
                else
                    echo "  skipped sudo kill for $pid"
                fi
            fi
        fi
    done
}
