#!/usr/bin/env bash
# SPDX-FileCopyrightText: © 2026 Tyler Nivin
# SPDX-License-Identifier: MIT
#
# ollm — one-shot generation against a local Ollama model, selected by role.
#
# Roles resolve to model tags from scripts/ollama_models.sh in the dotfiles checkout,
# found by resolving this script's own stow symlink back to the repo — the fragment
# stays the single source of truth (same file the installer and uninstall.sh read).
#
# Built for scripted callers (Claude Code offload) as much as interactive use: the
# model's text is the only thing on stdout; every diagnostic goes to stderr. Thinking
# is disabled by default (hidden reasoning otherwise eats the token budget and yields
# an empty response); --think opts in on models that support it.
set -euo pipefail

OLLM_URL="${OLLM_URL:-http://localhost:11434}"

usage() {
  cat <<'EOF'
Usage: ollm [options] [PROMPT...]

One-shot generation against a local Ollama model, selected by role.
The prompt is the joined PROMPT arguments; when stdin is not a TTY it is
appended after a blank line (pipe context in, pass the instruction as args).

Options:
  -r, --role ROLE      fast | bulk | brainstorm | vision   (default: fast,
                       or vision when --image is given)
  -m, --model TAG      explicit model tag (overrides --role)
      --think          enable thinking (off by default; errors on models
                       that cannot think)
  -n, --num-predict N  max tokens to generate (default: 4096)
  -i, --image PATH     attach an image (vision models)
  -t, --timeout SECS   overall request timeout (default: 300)
  -l, --list           show roles, resolved tags, and installed state
  -h, --help           show this help

Roles (tags live in scripts/ollama_models.sh):
  fast        high-volume, low-stakes text: classify, triage, summarize
  bulk        heavier coding offload (MLX machines)
  brainstorm  generalist: brainstorm, summarize, first-pass analysis
  vision      screenshots, diagrams, rough OCR
EOF
}

die() {
  echo "ollm: $*" >&2
  exit 1
}

usage_err() {
  echo "ollm: $*" >&2
  echo "try: ollm --help" >&2
  exit 2
}

# Locate the shared models fragment: OLLM_MODELS_FILE wins (tests, unstowed use);
# otherwise resolve this script's symlink to <repo>/home/.local/bin/ollm and walk
# back to <repo>/scripts/ollama_models.sh.
models_file() {
  if [ -n "${OLLM_MODELS_FILE:-}" ]; then
    printf '%s\n' "$OLLM_MODELS_FILE"
    return
  fi
  local self dir
  self="$(readlink -f "$0")" || die "cannot resolve my own path"
  dir="$(dirname "$self")"
  case "$dir" in
  */home/.local/bin) printf '%s\n' "${dir%/home/.local/bin}/scripts/ollama_models.sh" ;;
  *) die "not running from a stowed dotfiles checkout; set OLLM_MODELS_FILE to your ollama_models.sh" ;;
  esac
}

ROLES=(fast bulk brainstorm vision)

# Source the fragment once per process, populating the OLLAMA_* role vars. Subshells
# inherit both the vars and the guard, so $(role_to_model ...) doesn't re-source.
load_models() {
  [ -z "${_OLLM_MODELS_LOADED:-}" ] || return 0
  local file
  file="$(models_file)"
  # shellcheck source=../../../scripts/ollama_models.sh disable=SC1091
  . "$file" 2>/dev/null || die "cannot read models fragment $file"
  _OLLM_MODELS_LOADED=1
}

role_to_model() {
  load_models
  case "$1" in
  fast) printf '%s\n' "${OLLAMA_MODEL:?}" ;;
  bulk) printf '%s\n' "${OLLAMA_MLX_MODEL:?}" ;;
  brainstorm) printf '%s\n' "${OLLAMA_BRAINSTORM_MODEL:?}" ;;
  vision) printf '%s\n' "${OLLAMA_VISION_MODEL:?}" ;;
  *) usage_err "unknown role: $1 (fast|bulk|brainstorm|vision)" ;;
  esac
}

server_up() {
  curl -fsS -m 2 "$OLLM_URL/api/tags" >/dev/null 2>&1
}

# Whether the model advertises the "thinking" capability. Ollama rejects a request
# that sends `think` to a model without it, so the field is only ever set when
# the capability is present.
supports_thinking() {
  curl -fsS -m 10 -X POST "$OLLM_URL/api/show" \
    -d "$(jq -cn --arg m "$1" '{model: $m}')" 2>/dev/null |
    jq -e '.capabilities // [] | index("thinking")' >/dev/null 2>&1
}

list_models() {
  server_up || die "Ollama server not responding at $OLLM_URL (start the Ollama app or run 'ollama serve')"
  load_models
  local installed role model marker
  installed="$(curl -fsS -m 5 "$OLLM_URL/api/tags" 2>/dev/null | jq -r '.models[].name' 2>/dev/null)" || installed=""
  for role in "${ROLES[@]}"; do
    model="$(role_to_model "$role")"
    marker="missing"
    if printf '%s\n' "$installed" | grep -qxF "$model"; then
      marker="installed"
    fi
    printf '%-12s %-36s %s\n' "$role" "$model" "$marker"
  done
}

main() {
  local role="" model="" think=false num_predict=4096 image="" timeout=300 list=false
  local -a prompt_args=()

  while [ $# -gt 0 ]; do
    case "$1" in
    -r | --role)
      [ $# -ge 2 ] || usage_err "$1 needs a value"
      role="$2"
      shift 2
      ;;
    -m | --model)
      [ $# -ge 2 ] || usage_err "$1 needs a value"
      model="$2"
      shift 2
      ;;
    --think)
      think=true
      shift
      ;;
    -n | --num-predict)
      [ $# -ge 2 ] || usage_err "$1 needs a value"
      case "$2" in '' | *[!0-9]*) usage_err "--num-predict needs a positive integer" ;; esac
      num_predict="$2"
      shift 2
      ;;
    -i | --image)
      [ $# -ge 2 ] || usage_err "$1 needs a value"
      image="$2"
      shift 2
      ;;
    -t | --timeout)
      [ $# -ge 2 ] || usage_err "$1 needs a value"
      case "$2" in '' | *[!0-9]*) usage_err "--timeout needs a positive integer" ;; esac
      timeout="$2"
      shift 2
      ;;
    -l | --list)
      list=true
      shift
      ;;
    -h | --help)
      usage
      return 0
      ;;
    --)
      shift
      prompt_args+=("$@")
      break
      ;;
    -*)
      usage_err "unknown option: $1"
      ;;
    *)
      prompt_args+=("$1")
      shift
      ;;
    esac
  done

  command -v jq >/dev/null 2>&1 || die "jq is required (brew install jq — it's in the Brewfile)"

  if $list; then
    list_models
    return 0
  fi

  # Prompt = joined args, then piped stdin after a blank line.
  local prompt="" stdin_data=""
  [ ${#prompt_args[@]} -gt 0 ] && prompt="${prompt_args[*]}"
  if [ ! -t 0 ]; then
    stdin_data="$(cat)"
  fi
  if [ -n "$prompt" ] && [ -n "$stdin_data" ]; then
    prompt="$prompt

$stdin_data"
  elif [ -z "$prompt" ]; then
    prompt="$stdin_data"
  fi
  [ -n "$prompt" ] || usage_err "no prompt (pass arguments or pipe stdin)"

  # An image with no explicit role means the vision model.
  if [ -n "$image" ] && [ -z "$role" ] && [ -z "$model" ]; then
    role="vision"
  fi
  [ -n "$model" ] || model="$(role_to_model "${role:-fast}")"

  server_up || die "Ollama server not responding at $OLLM_URL (start the Ollama app or run 'ollama serve')"

  local payload
  payload="$(jq -cn --arg model "$model" --arg prompt "$prompt" --argjson np "$num_predict" \
    '{model: $model, prompt: $prompt, stream: false, options: {num_predict: $np}}')"

  if supports_thinking "$model"; then
    payload="$(jq -c --argjson t "$think" '. + {think: $t}' <<<"$payload")"
  elif $think; then
    die "model $model does not support thinking"
  fi

  if [ -n "$image" ]; then
    [ -f "$image" ] || die "image not found: $image"
    local b64
    b64="$(base64 <"$image" | tr -d '\n')"
    payload="$(jq -c --arg img "$b64" '. + {images: [$img]}' <<<"$payload")"
  fi

  local resp
  resp="$(curl -sS --connect-timeout 5 -m "$timeout" -X POST "$OLLM_URL/api/generate" -d "$payload")" ||
    die "request to $OLLM_URL/api/generate failed"

  local err
  err="$(jq -r '.error // empty' <<<"$resp" 2>/dev/null)" || die "unparsable response from Ollama"
  [ -z "$err" ] || die "Ollama: $err"

  local text done_reason
  text="$(jq -r '.response // empty' <<<"$resp")"
  if [ -z "$text" ]; then
    done_reason="$(jq -r '.done_reason // "unknown"' <<<"$resp")"
    if [ "$done_reason" = "length" ]; then
      die "empty response, done_reason=length — the token budget ran out before any text (raise --num-predict; thinking is already ${think})"
    fi
    die "empty response (done_reason=$done_reason)"
  fi
  printf '%s\n' "$text"
}

main "$@"
