{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pytest *)",
      "Bash(prek run *)",
      "Bash(bash -n *)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:code.claude.com)",
      "Bash(trivy fs *)",
      "Bash(brew leaves *)",
      "Bash(brew list *)",
      "Bash(brew info *)"
    ],
    "deny": [
      "Read(*.env)",
      "Read(**/*.pem)",
      "Bash(git clean*)"
    ],
    "defaultMode": "default"
  },
  "extraKnownMarketplaces": {
    "nivintw-claude-skills": {
      "source": {
        "source": "github",
        "repo": "nivintw/nivintw-claude-skills"
      }
    }
  },
  "effortLevel": "high",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "enabledPlugins": {
    "castify@nivintw-claude-skills": true
  }
}
