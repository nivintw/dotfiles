{
  "1password": {
    "type": "stdio",
    "command": "/Applications/1Password.app/Contents/MacOS/onepassword-mcp",
    "args": [],
    "env": {}
  },
  "github": {
    "type": "http",
    "url": "https://api.githubcopilot.com/mcp/",
    "headers": {
      "Authorization": "Bearer {{ op://MCP/github-claude-pat/credential }}"
    }
  },
  "context7": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@upstash/context7-mcp"]
  },
  "playwright": {
    "type": "stdio",
    "command": "npx",
    "args": ["-y", "@playwright/mcp@latest"]
  },
  "serena": {
    "type": "stdio",
    "command": "uvx",
    "args": [
      "--from",
      "git+https://github.com/oraios/serena",
      "serena",
      "start-mcp-server",
      "--project-from-cwd",
      "--context",
      "claude-code",
      "--open-web-dashboard",
      "False"
    ],
    "env": {
      "MCP_TIMEOUT": "200000"
    }
  }
}
