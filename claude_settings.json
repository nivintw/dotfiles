{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(uv run ruff *)",
      "Bash(uv run pytest *)",
      "Bash(prek run *)",
      "Bash(bash -n *)",
      "WebFetch(domain:docs.docker.com)",
      "WebFetch(domain:docs.google.com)",
      "WebFetch(domain:docs.python.org)",
      "WebFetch(domain:code.claude.com)",
      "Bash(trivy fs *)",
      "Bash(brew leaves *)",
      "Bash(brew list *)",
      "Bash(brew info *)"
    ],
    "deny": ["Read(**/*.env)", "Read(**/*.pem)", "Bash(git clean*)"],
    "defaultMode": "auto"
  },
  "enabledPlugins": {
    "castify@nivintw-claude-skills": true,
    "skill-creator@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "session-report@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "worktree-guard@nivintw-claude-skills": true,
    "dev-kit@nivintw-claude-skills": true,
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "claude-hud@claude-hud": true
  },
  "extraKnownMarketplaces": {
    "nivintw-claude-skills": {
      "source": {
        "source": "github",
        "repo": "nivintw/nivintw-claude-skills"
      },
      "autoUpdate": true
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "[ ! -x \"$HOME/.claude/hooks/ollama-roster.sh\" ] || \"$HOME/.claude/hooks/ollama-roster.sh\""
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
