# Opt-in Brewfile bundle (Ruby DSL, same syntax as Brewfile — no extension; the
# Brewfile.d/<name> path is just how install.sh and the directive test find it).
# Installed only when "personal" is listed in ~/.config/dotfiles/brewfiles (see
# install.sh step 1 and "Machine-local overlays" in the README). Holds software
# not wanted on every machine — personal apps, or things that are work-managed on
# a work box. Tracked & public; for machine-PRIVATE additions use the untracked
# ~/.config/dotfiles/Brewfile.local instead. New bundles just need this two-line
# SPDX header (hawkeye leaves them alone; REUSE checks the header is present).

# --- Media & gaming --------------------------------------------------------
cask "discord"               # Discord
cask "openemu"               # Retro game console emulator
cask "steam"                 # Steam game client

# --- Hardware & 3D printing ------------------------------------------------
cask "creality-print"        # Slicer for Creality FDM 3D printers
cask "raspberry-pi-imager"   # Flash Raspberry Pi OS images to SD cards

# --- Productivity (personal, or work-managed on a work machine) ------------
cask "anki"                  # Spaced-repetition flashcards
cask "microsoft-office"      # Office 365 (work-managed on a work machine). Bundles "Defender Shim"; conflicts with a standalone onedrive cask, so don't add one.
cask "resilio-sync"          # Peer-to-peer file sync
